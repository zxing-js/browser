{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "module": "commonjs",
    "target": "es2017",
    "moduleResolution": "node",
    "rootDir": ".",
    "lib": ["es2020", "dom"],
    "alwaysStrict": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "declaration": false,
    "downlevelIteration": true,
    "esModuleInterop": true,
    "types": ["jest", "node"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
